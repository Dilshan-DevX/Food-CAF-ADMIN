<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@android:color/white">

    <!-- Profile Image + Name header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <androidx.cardview.widget.CardView
            android:layout_width="84dp"
            android:layout_height="84dp"
            app:cardCornerRadius="42dp"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/dialogImgProfile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_myplaces" />

        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/dialogTvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textColor="#1A1F2E"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/dialogChipStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Active"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            app:chipBackgroundColor="#6DBE82"
            app:chipCornerRadius="10dp"
            app:chipMinHeight="26dp"
            app:ensureMinTouchTargetSize="false"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- Detail rows -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F8F9FB"
        android:padding="14dp">

        <!-- Email -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Email"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialogTvEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textColor="#333333"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Phone -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Phone"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialogTvPhone"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textColor="#333333"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Address -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="Address"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialogTvAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textColor="#333333"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- User ID -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="90dp"
                android:layout_height="wrap_content"
                android:text="User ID"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dialogTvUid"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:ellipsize="end"
                android:maxLines="1" />

        </LinearLayout>

    </LinearLayout>

    <!-- Close button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/dialogBtnClose"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="20dp"
        android:text="Close"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:backgroundTint="#1A1F2E"
        app:cornerRadius="14dp"
        app:elevation="0dp" />

</LinearLayout>