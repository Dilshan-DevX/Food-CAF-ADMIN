<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F1218">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="47dp"
        android:background="#0F1218"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Banner Management"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="40dp">


            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1E2433"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2A3345">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CURRENT BANNER"
                        android:textColor="#6DBE82"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />


                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="0dp">

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/imgBannerPreview"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@android:drawable/ic_menu_gallery" />

                            <LinearLayout
                                android:id="@+id/bannerImagePlaceholder"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:background="#2A3345"
                                android:visibility="gone">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="🖼"
                                    android:textSize="32sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="No banner image"
                                    android:textColor="#888888"
                                    android:textSize="12sp"
                                    android:layout_marginTop="8dp" />

                            </LinearLayout>

                        </FrameLayout>
                    </androidx.cardview.widget.CardView>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TITLE"
                                android:textColor="#555555"
                                android:textSize="9sp"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/tvCurrentTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Loading..."
                                android:textColor="#CCCCCC"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="end">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DATE"
                                android:textColor="#555555"
                                android:textSize="9sp"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/tvCurrentDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textColor="#6DBE82"
                                android:textSize="13sp"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1E2433"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#2A3345">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="EDIT BANNER"
                        android:textColor="#F5A623"
                        android:textSize="10sp"
                        android:letterSpacing="0.12"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp" />


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Title"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#6DBE82"
                        app:boxBackgroundColor="#151B27">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBannerTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. New Year Offer"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#555555"
                            android:textSize="14sp"
                            android:inputType="text" />

                    </com.google.android.material.textfield.TextInputLayout>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Body / Offer Text"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#6DBE82"
                        app:boxBackgroundColor="#151B27">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBannerBody"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. 30% OFF"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#555555"
                            android:textSize="14sp"
                            android:inputType="text" />

                    </com.google.android.material.textfield.TextInputLayout>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date Range"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxStrokeColor="#6DBE82"
                        app:boxBackgroundColor="#151B27">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBannerDate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. 16 - 31 Dec"
                            android:textColor="#FFFFFF"
                            android:textColorHint="#555555"
                            android:textSize="14sp"
                            android:inputType="text" />

                    </com.google.android.material.textfield.TextInputLayout>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Banner Image"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:layout_marginBottom="8dp" />


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">


                        <androidx.cardview.widget.CardView
                            android:layout_width="80dp"
                            android:layout_height="60dp"
                            app:cardCornerRadius="10dp"
                            app:cardElevation="0dp"
                            android:layout_marginEnd="12dp">

                            <ImageView
                                android:id="@+id/imgSelectedPreview"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@android:drawable/ic_menu_gallery"
                                android:background="#2A3345" />

                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvImageStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No image selected"
                                android:textColor="#888888"
                                android:textSize="12sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnPickImage"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:layout_marginTop="8dp"
                                android:text="Choose Image"
                                android:textSize="12sp"
                                android:textColor="#0F1218"
                                android:textStyle="bold"
                                app:backgroundTint="#6DBE82"
                                app:cornerRadius="18dp"
                                app:elevation="0dp" />

                        </LinearLayout>
                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/uploadProgressLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="6dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Uploading image..."
                                android:textColor="#CCCCCC"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/tvUploadPercent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="#6DBE82"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/uploadProgress"
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:max="100"
                            android:progress="0"
                            android:progressTint="#6DBE82"
                            android:progressBackgroundTint="#2A3345" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveBanner"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="SAVE BANNER"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#0F1218"
                app:backgroundTint="#6DBE82"
                app:cornerRadius="28dp"
                app:elevation="0dp"
                app:iconSize="18dp"
                app:iconTint="#0F1218" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>