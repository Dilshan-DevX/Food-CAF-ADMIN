<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F1218">




    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Product Images — image 2k horizontal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                >

                <!-- Image 1 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#1E2433"
                    android:layout_marginBottom="5dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginStart="5dp">

                    <ImageView
                        android:id="@+id/imgProduct"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery" />

                </androidx.cardview.widget.CardView>

                <!-- Image 2 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#1E2433"
                    android:layout_marginBottom="5dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginEnd="5dp">

                    <ImageView
                        android:id="@+id/imgProduct2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_gallery" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Main Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#1E2433"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Title + Availability -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <EditText
                            android:id="@+id/etFoodTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Product Name"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColorHint="@color/white"
                            android:textColor="@color/white"
                            android:background="@null"
                            android:padding="0dp"
                            android:inputType="text" />

                        <!-- Availability Switch -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvAvailabilityLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Available"
                                android:textSize="12sp"
                                android:textColor="#2EBA63"
                                android:layout_marginEnd="6dp" />

                            <com.google.android.material.switchmaterial.SwitchMaterial
                                android:id="@+id/switchAvailability"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginVertical="12dp" />

                    <!-- Price + Rating + Time row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Price -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Price (LKR)"
                                android:textSize="11sp"
                                android:textColor="#999999" />

                            <EditText
                                android:id="@+id/etPrice"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="0.00"
                                android:textSize="15sp"
                                android:textColor="@color/white"
                                android:textColorHint="@color/white"
                                android:inputType="numberDecimal"
                                android:background="@null"
                                android:padding="0dp" />
                        </LinearLayout>

                        <!-- Rating -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rating"
                                android:textSize="11sp"
                                android:textColor="#999999" />

                            <EditText
                                android:id="@+id/etRating"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="4.5"
                                android:textSize="15sp"
                                android:textColor="@color/white"
                                android:textColorHint="@color/white"
                                android:inputType="numberDecimal"
                                android:background="@null"
                                android:padding="0dp" />
                        </LinearLayout>

                        <!-- Time -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Prep Time"
                                android:textSize="11sp"
                                android:textColor="#999999" />

                            <EditText
                                android:id="@+id/etFoodTime"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="30 min"
                                android:textSize="15sp"
                                android:textColor="@color/white"
                                android:textColorHint="@color/white"
                                android:inputType="text"
                                android:background="@null"
                                android:padding="0dp" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Details Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#1E2433"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Description"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etFoodDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter food description..."
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white"
                        android:inputType="textMultiLine"
                        android:minLines="3"
                        android:gravity="top"
                        android:background="@null"
                        android:padding="0dp"
                        android:layout_marginTop="6dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginVertical="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ingredients"
                        android:textSize="13sp"
                        android:textColor="#999999"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etIngredients"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter ingredients..."
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:gravity="top"
                        android:background="@null"
                        android:padding="0dp"
                        android:layout_marginTop="6dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Category DropDown -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#1E2433"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"

                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Category"
                        android:textSize="11sp"
                        android:textColor="#999999"
                        android:textStyle="bold" />

                    <!-- Material Exposed DropDown Menu -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxStrokeColor="#E0E0E0"
                        app:hintTextColor="@color/white">

                        <AutoCompleteTextView
                            android:id="@+id/dropdownCategory"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Select Category"
                            android:textSize="14sp"
                            android:textColor="@color/white"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="14dp"
                            android:inputType="none"
                            android:focusable="false"
                            android:cursorVisible="false" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Update Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUpdate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="12dp"
        android:text="UPDATE PRODUCT"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="#2EBA63"
        app:cornerRadius="28dp"
        app:elevation="0dp" />

</LinearLayout>